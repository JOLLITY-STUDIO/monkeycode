{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": ".",
    "target": "ES2022",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["game/**/*.ts"],
  "exclude": ["node_modules", "test", "legacy"]
}

