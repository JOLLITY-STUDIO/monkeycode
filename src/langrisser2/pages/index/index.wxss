@import '../../app.wxss';

/**
 * pages/index/index.wxss — 游戏页面样式
 */

.game-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #0a0a0a;
  overflow: hidden;
}

.canvas-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.game-canvas {
  border: 1px solid #333;
  background: #000;
}

.status-bar {
  width: 100%;
  padding: 6px 16px;
  background: #0a0a0a;
  border-top: 1px solid #1a1a2e;
  text-align: center;
}

.status-text {
  font-size: 12px;
  color: #e94560;
  font-family: 'Courier New', monospace;
}

.hints {
  padding: 2px 16px 6px;
  background: #0a0a0a;
  width: 100%;
  text-align: center;
}

.hint-text {
  font-size: 11px;
  color: #555;
  font-family: 'Courier New', monospace;
}
